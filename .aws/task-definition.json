{
  "family": "monew",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::633267924791:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::633267924791:role/monewTaskRole",
  "containerDefinitions": [
    {
      "name": "monew",
      "image": "633267924791.dkr.ecr.ap-northeast-2.amazonaws.com/monew:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        },
        {
          "name": "SERVER_PORT",
          "value": "8080"
        },
        {
          "name": "MONEW_NEWS_SCHEDULER_ENABLED",
          "value": "true"
        },
        {
          "name": "MONEW_NEWS_CRON",
          "value": "0 0 * * * *"
        }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/db-url"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/db-username"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/db-password"
        },
        {
          "name": "SPRING_DATA_MONGODB_URI",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/mongo-uri"
        },
        {
          "name": "AWS_S3_BUCKET",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/s3-bucket"
        },
        {
          "name": "NAVER_CLIENT_ID",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/naver-client-id"
        },
        {
          "name": "NAVER_CLIENT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:633267924791:parameter/monew/naver-client-secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/monew",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8080/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}

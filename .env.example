# 로컬 개발용 환경변수 템플릿. 복사해서 .env로 저장하세요.
# .env는 .gitignore에 포함되어 형상관리에서 제외됩니다.

# Database - PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/monew
SPRING_DATASOURCE_USERNAME=monew
SPRING_DATASOURCE_PASSWORD=monew

# Database - MongoDB
SPRING_DATA_MONGODB_URI=mongodb://monew:monew@localhost:27017/monew?authSource=admin

# AWS S3 (백업/복구)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=monew-backup
